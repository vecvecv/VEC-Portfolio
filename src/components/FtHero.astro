---
//HERO de FICTION TRACK
import backg from '../assets/ft-hero-back.png';



---

<div id="container">

	<img src={backg.src} width="1280" height="832" alt="Fiction Track App" />	 
    

	
</div>

<style>
    .container{
        position: absolute;
         z-index: 0;
    }
	main{
		width: 100%;
		height: calc(100vh - 60px);
		margin: 0 auto;
		z-index: 3;
		display: flex;
		justify-content: center;
		font-family: 'Inter';
        z-index: 1;
		
		
	}

	.vec-logo{
		animation: fade 3s ease-in ;

	}

	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}
	p{
		font-family: 'Inter';
		font-style: normal;
		font-weight: 400;
		font-size: 16px;
		color: #140213;
		letter-spacing: 0.04em;
		text-decoration: none;
	}

	 .tag {
    font-size: 1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 1;
    margin-bottom: 12px;
	color: #fff;
	text-shadow: 2px 2px 6px #1e0125;
  }

  h1 {
	animation: fade 3s ease-in ;
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 0;
    font-weight: 700;
	opacity: 0.6;
	color: #fff;
	text-shadow: 2px 2px 6px #1e0125;
  }

  h2 {
	animation: fade 3.5s ease-in ;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-top: 8px;
    font-weight: 400;
    opacity: 0.85;
	color: #fff;
	text-shadow: 2px 2px 6px #1e0125;
  }

	#hero{
		display: flex;
		flex-direction: column;
		flex-wrap: nowrap;
		justify-content: center;
		align-items: center;
		
	}
    img{
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: relative;
        top: -100;
        left: 0;
    }

	
	#botones{
		display: flex;
		gap: 15px;
		flex-direction: column;
    	flex-wrap: nowrap;
    	align-items: center;
	}

	.button{
		padding: 15px 60px;
		background-color: #FF459B;
		border-radius: 25px;
		font-family: 'Inter';
		font-style: normal;
		font-weight: 400;
		font-size: 15px;
		color: #FFFFFF;
		letter-spacing: 0.04em;
		text-decoration: none;

	}
</style>
