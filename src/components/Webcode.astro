---
//BLOQUE DE WEB CODE Y DESIGN EN EL HOME

import vectesoro from '../assets/vectesoro.png';
import ArenaFondo from './ArenaFondo.astro';
---

<div id="container">
    <ArenaFondo></ArenaFondo>
    <div class="main">
        <div class="imagen">
            <img src={vectesoro.src} width="700" height="510" alt="VECVECVEC" />
        </div>
        <div class="descripcion">
            <h1>Thank you for <br> being here.</h1>
            <p>
I’ve always been drawn to motion: it’s part of how I understand ideas and bring them to life. <br>Today, I’m focused on applying that to the web.
I design with discernment, while also understanding development, product logic, and performance.<br>
I’m interested in design that works, which is why I also got into coding and advertising.
After 12 years, I’m still exploring, learning, and pushing my ideas further.


            </p>


        </div>
    </div>
    </div>
</div>

<style>
    	.main{
            display: flex;
            position: relative;
            width: 100%;
            height: 75vh;
            margin: 0 auto;
            z-index: 3;
            justify-content: center;
            font-family: 'Inter';
            color: #140213;
            justify-content: space-between;
            flex-direction: row;
            align-items: center;
            flex-wrap: nowrap;
            overflow-x: hidden; 
		
	}

    .imagen{
        width: 30%;
       
    }
    
    img{
        margin-left: 100px;
        margin-bottom: 100px;
    }
    
    .descripcion{
        width: 50%;
            }



    h1{
        animation: fade 1s ease-in ;
        font-size: clamp(2.5rem, 5vw, 4rem);
        margin-top: -100px;
        font-weight: 700;
        margin-right:10px;
        color: #FFFFFF; 
        text-shadow: 2px 2px 6px #1e0125;
        }

    p{
        animation: fade 1s ease-in ;
        font-family: 'Inter';
        font-style: normal;
        font-weight: 4  00;
        font-size: 16px;
        line-height: 19px;
        letter-spacing: 0.04em;
        color: #FFFFFF; 
        line-height: 40px;
        padding: 0px 450px 10px 00px;
        margin-top: -20px;
        margin-left: 5px;
    }


    @media (max-width: 768px) {
    .main {
        flex-direction: column;
        height: auto;
        padding: 2rem 1.5rem;
        align-items: flex-start;
        justify-content: flex-start;
    }

    .imagen {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    img {
        margin-left: 0;
        margin-bottom: 1rem;
        width: 80%;
        height: auto;
    }

    .descripcion {
        width: 100%;
    }

    h1 {
        margin-top: 0;
        margin-right: 0;
    }

    p {
        padding: 0;
        margin-left: 0;
        font-size: 15px;
        line-height: 28px;
    }



    	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}



</style>