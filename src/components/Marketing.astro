---
//BLOQUE MARKETING EN EL HOME
import FondoNubes from "./FondoNubes.astro";
import almabikes from '../assets/almabikes/almabikes.png';
---

<div id="container">
   <FondoNubes></FondoNubes>
    <div class="main">
        <div class="imagen">
         <img src={almabikes.src} alt="Alma Bikes" /> 
        </div>
        <div class="descripcion">
              
                
                <h1 class="titulo">ALMA BIKES</h1>
                <p class="tag">TURNING TRAFFIC INTO A SALES CHANNEL </p>
                <p class="parrafo"> A quick solution for a growing business. <br> 
                <strong>Under Construction</strong></p>
         
                <section id="botones">
                <a class="button" href="https://almabikes.com.ar/" target="_blank" rel="noopener noreferrer">Visit Site</a>
                
           
                            
                </section>  
        </div>
        </div>
        
    </div>

<style>

        #container{
            overflow-x: hidden; 
            
        }
    	.main{
           
            display: flex;
            flex-direction: row;
            flex-wrap: nowrap;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 100vh;
            margin: 0 auto;
            font-family: 'Inter';
            color: #140213;
            overflow-x: hidden; 
            
            
 
		
	}

    .imagen{
        width: 50%;
        margin-left: 8rem;
          
    }
    img{
        width: 100%;
        margin-left: 8rem;
    }

    .descripcion{
        width: 50%;
        padding: 100px;
    }

 .tag {
    font-size: 1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 1;
    
	color:#ffffff;
	text-shadow: 0px 0px 7px #FF5F21;+
     line-height: 22px;
    
  }

h1{
        animation: fade 1s ease-in ;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        color: #FFFFFF; 
        text-shadow: 2px 2px 6px #1e0125;
        padding: 0;
        margin: 0px 0px 20px 0px;
        }

    .parrafo{
        animation: fade 1s ease-in ;
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 16px;
        line-height: 19px;
        letter-spacing: 0.04em;
        color: #FFFFFF; 
        line-height: 40px;
        padding: 0px;
       
    }


    	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}

    
 .button{

                display: flex;
                flex-direction: row;
                justify-content: center;
                align-items: center;
                padding: 15px 65px;
                gap: 10px;
                color: #fff;
                text-decoration: none;
                position: absolute;
              
             

                background: #FF5F21;
                border-radius: 25px;

    }

    @media (max-width: 768px) {
    .main {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
        padding: 2rem 1.5rem;
        align-items: flex-start;
        
    }

    .imagen {
        width: 100%;
        margin-left: 0;
    }

    img {
        width: 100%;
        margin-left: 0;
    }

    .descripcion {
        width: 100%;
        padding: 1rem 0;
    }

    .button {
        position: relative;
        display: inline-flex;
        padding: 12px 40px;
        margin-top: 1.5rem;
    }
}
</style>