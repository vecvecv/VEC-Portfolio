---
const nubes = [
  { id: 1, type: 'nube1', size: 0.8, speed: 120, delay: 0, top: 15, opacity: 0.7 },
  { id: 2, type: 'nube2', size: 1.2, speed: 150, delay: 5, top: 25, opacity: 0.5 },
  { id: 3, type: 'nube3', size: 0.6, speed: 180, delay: 10, top: 10, opacity: 0.4 },
  { id: 4, type: 'nube1', size: 1.0, speed: 200, delay: 15, top: 30, opacity: 0.3 },
  { id: 5, type: 'nube2', size: 0.9, speed: 170, delay: 8, top: 20, opacity: 0.6 }
];
---

<div class="fondo-nubes">
  <!-- Fondo con degradado -->
  <div class="degradado-fondo"></div>
  
  <!-- Nubes animadas -->
  <div class="nubes-container">
    {nubes.map(nube => (
      <div 
        class="nube"
        style={`
          --size: ${nube.size};
          --speed: ${nube.speed}s;
          --delay: ${nube.delay}s;
          --top: ${nube.top}%;
          --opacity: ${nube.opacity};
        `}
      >
        {nube.type === 'nube1' && (
          <svg id="nube1" width="295" height="185" viewBox="0 0 295 185">
            <circle cx="66" cy="119" r="66" fill="#FFF2FE"/>
            <circle cx="139" cy="119" r="66" fill="#FFF2FE"/>
            <circle cx="198" cy="119" r="53" fill="#FFF2FE"/>
            <circle cx="205" cy="66" r="53" fill="#FFF2FE"/>
            <circle cx="126" cy="53" r="53" fill="#FFF2FE"/>
            <circle cx="258" cy="119" r="37" fill="#FFF2FE"/>
          </svg>
        )}
        
        {nube.type === 'nube2' && (
          <svg id="nube2" width="270" height="161" viewBox="0 0 270 161">
            <circle cx="57.257" cy="57.257" r="57.257" transform="matrix(-1 0 0 1 270 28.0815)" fill="#FFF2FE"/>
            <circle cx="57.257" cy="57.257" r="57.257" transform="matrix(-1 0 0 1 206.67 45.979)" fill="#FFF2FE"/>
            <circle cx="45.9791" cy="45.9791" r="45.9791" transform="matrix(-1 0 0 1 144.208 57.2571)" fill="#FFF2FE"/>
            <circle cx="45.9791" cy="45.9791" r="45.9791" transform="matrix(-1 0 0 1 91.9583 35.665)" fill="#FFF2FE"/>
            <circle cx="45.9791" cy="45.9791" r="45.9791" transform="matrix(-1 0 0 1 166.613 0)" fill="#FFF2FE"/>
            <circle cx="32.0986" cy="32.0986" r="32.0986" transform="matrix(-1 0 0 1 219.998 3.75415)" fill="#FFF2FE"/>
          </svg>
        )}
        
        {nube.type === 'nube3' && (
          <svg id="nube3" width="295" height="185" viewBox="0 0 295 185">
            <circle cx="66" cy="119" r="66" fill="#FFF2FE"/>
            <circle cx="139" cy="119" r="66" fill="#FFF2FE"/>
            <circle cx="198" cy="119" r="53" fill="#FFF2FE"/>
            <circle cx="205" cy="66" r="53" fill="#FFF2FE"/>
            <circle cx="126" cy="53" r="53" fill="#FFF2FE"/>
            <circle cx="258" cy="119" r="37" fill="#FFF2FE"/>
          </svg>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .fondo-nubes {
    position: absolute;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    z-index: -1;
  }

  .degradado-fondo {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(179deg, #4415FE 0%, #F985BC 50%, #F6D5F7 100%);
    z-index: -1;
  }

  .nubes-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .nube {
    position: absolute;
    top: var(--top);
    left: -300px;
    width: calc(295px * var(--size));
    height: calc(185px * var(--size));
    opacity: var(--opacity);
    animation: mover-nube var(--speed) linear infinite;
    animation-delay: var(--delay);
    will-change: transform;
  }

  .nube svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.1));
  }

  @keyframes mover-nube {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(100vw + 300px));
    }
  }

  /* Ajustes específicos para nube2 que tiene dimensiones diferentes */
  .nube #nube2 {
    width: calc(270px * var(--size));
    height: calc(161px * var(--size));
  }
</style>