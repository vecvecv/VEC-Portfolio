---
import vecLogoSmall from '../assets/logo-vec-small.png';
const base = import.meta.env.BASE_URL;
---

<header>
    <div class="logo">
        <a href={base}>
            <img src={vecLogoSmall.src} width="107" height="63" alt="VECVECVEC" />
        </a>
    </div>
    <nav>
        <a href="#container-projects">PROJECTS</a>
        <a href="#">ABOUT</a>
        <a href="mailto:valdiviezocristinae@gmail.com">CONTACT ME</a>
    </nav>
</header>

<style>
    header{
        width: 100%;
        height: 60px;
        margin: 5px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        backdrop-filter: blur(10px);
        position: fixed;
        box-shadow: 0 2px 10px rgba(21, 0, 27, 0.1);
        z-index: 100;
        margin: 0 auto;
        
         }

      nav{
        display: flex;
        gap: 16px;
        margin-right: 50px;
        list-style: none;
        
      }   

      a{
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 15px;
        color: #ffffff;
        letter-spacing: 0.04em;
        text-decoration: none;
      }
      img{
        margin: 10px;
      }

      @media (max-width: 768px){
    a{
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 11px;
        color: #ffffff;
        letter-spacing: 0.04em;
        text-decoration: none;
      }

          nav{
        display: flex;
        gap: 16px;
        margin: 10px;
        list-style: none;
        
      }   

      }
</style>