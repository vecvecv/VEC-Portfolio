---
const gaviotas = [
  { id: 1, size: 0.5, speed: 25, delay: 0, left: 10, top: 15 },
  { id: 2, size: 0.7, speed: 30, delay: 5, left: 30, top: 20 },
  { id: 3, size: 0.3, speed: 35, delay: 8, left: 15, top: 25 }
];
---

<div class="gaviotas-container">
  {gaviotas.map(gaviota => (
    <svg 
      class="gaviota"
      style={`
        --size: ${gaviota.size};
        --speed: ${gaviota.speed}s;
        --delay: ${gaviota.delay}s;
        left: ${gaviota.left}%;
        top: ${gaviota.top}%;
      `}
      width="320" 
      height="288" 
      viewBox="0 0 100 18"
    >

  <!-- ala izquierda -->
  <rect x="2" y="10" width="10" height="4" fill="#2b2b2b"/>
  
  <!-- ala derecha -->
  <rect x="48" y="10" width="10" height="4" fill="#2b2b2b"/>

  <!-- cuerpo -->
  <rect x="16" y="10" width="24" height="10" fill="#ffffff"/>
  <rect x="20" y="8" width="16" height="6" fill="#eaeaea"/>

  <!-- cabeza -->
  <rect x="36" y="12" width="6" height="6" fill="#ffffff"/>

  <!-- pico -->
  <rect x="42" y="14" width="6" height="4" fill="#f4b400"/>

  <!-- ojo -->
  <rect x="38" y="14" width="2" height="2" fill="#000000"/>

  <!-- sombra leve -->
  <rect x="20" y="18" width="16" height="2" fill="#dcdcdc"/>

    </svg>
  ))}
</div>

<style>
  .gaviotas-container {
    position: absolute;
    top: 20%;
    width: 100%;
    height: 10vh;
    z-index: 10;
    pointer-events: none;
    overflow: hidden; /* ← contiene las gaviotas mientras vuelan */
  }

  .gaviota {
    position: absolute;
    width: calc(100px * var(--size));
    height: calc(18px * var(--size));
    animation: 
      volar linear infinite var(--speed),
      flotar ease-in-out infinite 3s;
    animation-delay: var(--delay);
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.2));
    opacity: 0.9;
  }

  @keyframes volar {
    0% {
        transform: translateX(-100%) rotate(0deg);
    }
    90% {
        opacity: 0.9;
    }
    100% {
        transform: translateX(100vw) rotate(2deg); /* ← era 150vw */
        opacity: 0;
    }
  }

  @keyframes flotar {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }
</style>