 <div class="main">
        <section class="quote-section">
            <hr class="divider">

                <div class="quote-content">
                    <p class="quote-text">
                    How can we encourage movement in a more natural and sustainable way?
                    </p>
                <!-- <a href="#research" class="quote-link">link posible</a> -->
                </div>

            <hr class="divider">
        </section>

</div>



<style>

    	.main{
           display: flex;
            flex-direction: column;
            flex-wrap: nowrap;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 60vh;
            margin: 0 auto;
            z-index: 3;
           
            font-family: 'Inter';

 
		
	}

.quote-section {

  background-color: #ffffff;
  padding: 2rem 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.divider {
  width: 100%;
  border: none;
  border-top: 1px solid #7D92FF;
  margin: 0;
}

.quote-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  max-width: 700px;
  text-align: center;
  padding: 1.5rem 0;
}

.quote-text {
    animation: fade 1s ease-in-out ;
  font-size: 28px;
  font-weight: 400;
  color: #7D92FF;
  line-height: 1.5;
  margin: 0;
 
}

.quote-link {
  font-size: 11px;
  font-weight: 600;
  color: #7D92FF;
  letter-spacing: 0.1em;
  text-decoration: underline;
  text-underline-offset: 3px;
}


    	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}

</style>