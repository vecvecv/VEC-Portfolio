---
// HUELLAS ANIMACION
---
<svg width="75%" viewBox="0 0 625 420" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      .huella { opacity: 0; animation: fade 5s reverse infinite; }
      @keyframes fade {
        0%   { opacity: 0; }
        6%   { opacity: 0.5; }
        65%  { opacity: 0.5; }
        82%  { opacity: 0; }
        100% { opacity: 0; }
      }
      .h1 { animation-delay: 0.6s; }
      .h2 { animation-delay: 0.9s; }
      .h3 { animation-delay: 1.5s; }
      .h4 { animation-delay: 2.1s; }
    </style>
  </defs>

  <!-- HUELLA 1 - pie derecho -->
  <g class="huella h1" transform="translate(200, 335) rotate(-15) scale(3.5) translate(-8, -8.5)">
