<div class="cielo"></div>

<style>
  .cielo {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    background: linear-gradient(10deg, 
      #F6D5F7,  
      #FBE9D7,  
      #74BBE6 
    );
    background-size: 300% 300%;
    animation: animacionCielo 15s ease infinite;
    
  }

  @keyframes animacionCielo {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>