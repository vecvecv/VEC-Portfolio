---
import home from '../assets/homeee.png';
import titulo from '../assets/titulo.png';
import map from '../assets/map.png';
import perfil from '../assets/peerfill.png';
---
<div class="main">
    <div class="gallery">

    <div class="phone-wrap">
    <img src={home.src}  alt="Fiction Track App" />	
        <span class="phone-label">Home</span>
    </div>

    <div class="phone-wrap raise-1">
        <img src={titulo.src}  alt="Fiction Track App" />
        <span class="phone-label">Select an episode</span>
    </div>

    <div class="phone-wrap raise-2">
        <img src={map.src}  alt="Fiction Track App" />
        <span class="phone-label">Walking and Listening</span>
    </div>

    <div class="phone-wrap raise-3">
        <img src={perfil.src}  alt="Fiction Track App" />
        <span class="phone-label">Profile</span>
    </div>

    </div>
</div>

<style>

        	.main{
              display: flex;
              background: #F0F2FF;
background: linear-gradient(1deg,rgba(240, 242, 255, 1) 38%, rgba(255, 255, 255, 1) 79%);
  width: 100%;
  height: 100vh;
  justify-content: center;
  align-items: center;
  font-family: 'Inter';
  color: #7D92FF;
  overflow: hidden; /* 👈 esto corta el overflow horizontal */
 
		
	}

    .gallery {
    
  padding: 3rem 2rem;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 20px;
  width: 100%;
  box-sizing: border-box;
    overflow: hidden; /* 👈 esto corta el overflow horizontal */

}

.phone-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  flex: 1;           /* cada teléfono ocupa espacio proporcional */
  max-width: 250px;  /* pero no crece más de 250px */
    overflow: hidden; /* 👈 esto corta el overflow horizontal */

}

.phone-wrap img {

   width: 100%;       /* se adapta al ancho del wrap */
  height: auto;      /* mantiene proporción */
  border-radius: 24px;
    overflow: hidden; /* 👈 esto corta el overflow horizontal */

}

.phone-wrap.raise-1 { transform: translateY(-20px); }
.phone-wrap.raise-2 { transform: translateY(-40px); }
.phone-wrap.raise-3 { transform: translateY(-10px); }

.phone-label {
  font-size: 12px;
  color: #7D92FF;
  font-weight: 600;
  letter-spacing: 0.05em;
    overflow: hidden; /* 👈 esto corta el overflow horizontal */

}

@media (max-width: 768px){
    .phone-wrap img {

   width: 100%;       /* se adapta al ancho del wrap */
  height: auto;      /* mantiene proporción */
  border-radius: 14px;
    overflow: hidden; /* 👈 esto corta el overflow horizontal */

}
}
</style>