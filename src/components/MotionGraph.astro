---
//BLOQUE DISEÑO APP FICTION TRACK EN EL HOME
import FondoMar from './FondoMar.astro';
import Peces from './Peces.astro';
import fiction from '../assets/fiction-track.png';
const base = import.meta.env.BASE_URL;
---

<div id="container-projects">
  <FondoMar />
 
    <div class="main">
        
        <div class="descripcion">
              
                
                <h1 class="titulo">FICTION TRACK</h1>
                <p class="tag">An app that turns steps into progress </p>
                <p class="parrafo"> What if you could walk further without even realizing it?</p>
         
                <section id="botones">
                <a class="button" href={`${base}/FictionTrack`}>Know More</a>
           
            </section>     

        </div>

        <div class="imagen">
           <Peces />
            <img class="overlay" src={fiction.src} width="893" height="1637" alt="fiction-track" /> 
        </div>

    </div>
    </div>
</div>

<style>

    #container-projects{
        
    }
    	.main{
            display: flex;
          
            width: 100%;
            height: 100vh;
            margin: 0 auto;
            z-index: 3;
            justify-content: center;
            font-family: 'Inter';
            color: #140213;
            justify-content: space-between;
            flex-direction: row;
            align-items: center;
            flex-wrap: nowrap;
            z-index: 1;
            overflow-x: hidden; 
		
	}

    .imagen{
        width: 50%;
        position: relative;
        margin-top: -300px;
       }

   .overlay {
    position: absolute;
    top: 0;
    left: 0;
    /* ajustá según necesites: */
    width: 70%;
    height: 250%;
    object-fit: contain;
  }   
    .descripcion{
        width: 50%;
        padding: 100px;
        z-index: 1;
        margin-left: 100px;
    }

.tag {
    font-size: 1rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 1;
    
	color:#ffffff;
	text-shadow: 0px 0px 7px #7D92FF;+
     line-height: 22px;
     padding: 10px 0px;
    
  }

h1{
        animation: fade 1s ease-in ;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        color: #FFFFFF; 
        text-shadow: 2px 2px 6px #1e0125;
        padding: 0;
        margin: 0px 0px 20px 0px;
        }

    .parrafo{
        animation: fade 1s ease-in ;
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 16px;
        line-height: 19px;
        letter-spacing: 0.04em;
        color: #FFFFFF; 
        line-height: 40px;
        
       
    }


        .button{

                display: flex;
                flex-direction: row;
                justify-content: center;
                align-items: center;
                padding: 15px 65px;
                gap: 10px;
                color: #fff;
                text-decoration: none;
                position: absolute;
             
             

                background: #7D92FF;
                border-radius: 25px;

    }






    	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}



@media (max-width: 768px) {
    .main {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
        align-items: center;
        justify-content: flex-start;
        padding-top: 2rem;
    }

    .descripcion {
        width: 90%;
        padding: 1.5rem;
        margin-left: 0;
        order: 1;
    }

    .imagen {
        width: 85%;
        margin-top: 0;
        position: relative;
        order: 2;
        min-height: 400px;
    }

    .overlay {
        position: relative;
        width: 100%;
        height: auto;
        object-fit: contain;
        top: auto;
        left: auto;
    }

    .button {
        position: relative;
        display: inline-flex;
        padding: 12px 40px;
        margin-top: 1.5rem;
    }
}
</style>