---
//BLOQUE SOLUCION APP 

import mockp from '../assets/mockp.png';
---

<div id="container">

    <div class="main">
    
        <div class="descripcion">
                    <h1 class="titulo">The Solution
                    </h1>
                      <p class="parrafo">An app focused on the thrill of storytelling. <br>
                        Users can explore a library of over 1,000 authors and immerse themselves in stories designed to be experienced on the go. <br><br>
                        The experience has one key condition:<br>
                        👉 The story only advances when the user walks.<br>
                    </p>
                        As they move, the user:<br>
                        <ul>
                       <li> Unlocks new episodes</li>
                       <li> Progresses through the narrative</li>
                       <li>Stays connected with their favorite authors</li>
                        </ul>   
                    <p>
                       <br> In this way, the content ceases to be passive and becomes a reward.
                        The concept combines fiction and exercise, transforming an everyday habit into a meaningful experience that positively impacts the user’s mood and consistency.
                    </p>
                  
                  
        </div>

        <div class="imagen">
            <img src={mockp.src}  alt="VECVECVEC" /> 
        </div>

    </div>
</div>


<style>

        #container{
            z-index: 3;
        }
    	.main{
            display: flex;
            position: relative;
            width: 100%;
            height: 80vh;
            margin: 0 auto;
            z-index: 3;
            justify-content: center;
            font-family: 'Inter';
            color: #7D92FF;
            justify-content: space-between;
            flex-direction: row;
            align-items: center;
            flex-wrap: nowrap;
 
		
	}

    .imagen{
        width: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
       
    }


.imagen img {
  width: 100%;
  height: auto;
}
    .descripcion{
        width: 50%;
        margin-left: 10rem;
        padding-right: 10rem;
    }

 h1{
        animation: fade 1s ease-in ;
        font-size: clamp(2.5rem, 5vw, 4rem);
        margin-top: -100px;
        font-weight: 700;
        opacity: 0.6;
        
        text-shadow: 2px 2px 6px #7D92FF;
        }

    p{
        animation: fade 1s ease-in ;
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 15px;
        line-height: 19px;
        letter-spacing: 0.04em;
        line-height: 40px;
      
       
    }

    ul {
        
        animation: fade 1s ease-in ;
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-size: 15px;
        line-height: 19px;
        letter-spacing: 0.04em;
        line-height: 40px;
    
    
    }

    	@keyframes fade{
		0%{
			     opacity: 0;
      transform: translateY(30px);
		}
		100%{
			     opacity: 0.6;
      transform: translateY(0);
		}
	}

    
    .button{

            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            padding: 15px 65px;
            gap: 10px;
            color: #fff;
            text-decoration: none;

            width: 302px;
            height: 48px;
            position: relative;
            left: auto;

            background: #7A3A94;
            border-radius: 25px;

    }


    @media (max-width: 768px) {
    .main {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
        padding: 2rem 1.5rem;
        box-sizing: border-box;
    }

    .descripcion {
        width: 100%;
        margin-left: 0;
        padding-right: 0;
        order: 1;
    }

    .imagen {
        width: 100%;
        order: 2;
    }

    h1 {
        margin-top: 0;
    }

    p {
        line-height: 28px;
    }

    .button {
        position: relative;
        left: auto;
        top: auto;
        width: 100%;
        max-width: 300px;
        margin-top: 1.5rem;
    }
}
</style>